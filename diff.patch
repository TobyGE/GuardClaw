+    // For write: "/Users/.../file.js\ncontent..." or "path: ~/file, ..."
+    const pathMatch = firstLine.match(/^(\/[^\s→,]+)/i) || firstLine.match(/path:\s*([^\s,]+)/i) || firstLine.match(/file:\s*([^\s,]+)/i);
