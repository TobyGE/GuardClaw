+    // node -e with project file operations (not dangerous)
+    if (/node\s+-e.*readFileSync.*guardclaw/.test(s)) return 'SAFE';
+    if (/node\s+-e.*writeFileSync.*guardclaw/.test(s)) return 'WARNING';
