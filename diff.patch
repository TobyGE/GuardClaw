+  // ── Non-exec tools ──
+  if (tool === 'read') {
+    if (/\.(ssh|aws|gnupg)/.test(s) || /\.env$/.test(s) || /credentials/.test(s) || /id_rsa/.test(s)) return 'WARNING';
+    return 'SAFE';
+  }
