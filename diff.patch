+    if (/\/Users\/[^/]+\/\.(bashrc|zshrc|profile|bash_profile)/.test(filePath)) return 'BLOCK';
+    if (/~\/\.ssh\//.test(filePath) || /authorized_keys/.test(filePath)) return 'BLOCK';
