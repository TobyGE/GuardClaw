+    if (/curl.*-d\s+@.*\.(ssh|aws|env|key|pem)/.test(s)) return 'BLOCK';
+    if (/curl.*-F\s+.*file=@/.test(s) && !/(localhost|127\.0\.0\.1)/.test(s)) return 'BLOCK';
