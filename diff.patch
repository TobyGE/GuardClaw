+    if (/\|\s*(bash|sh|zsh)\b/.test(s)) return 'BLOCK';
+    if (/curl.*\|\s*(bash|sh)/.test(s)) return 'BLOCK';
+    // Append to shell config
+    if (/>>?\s*~\/\.(bashrc|zshrc|profile|ssh)/.test(s)) return 'BLOCK';
+    // Reverse shell
+    if (/\bnc\b.*-e\s/.test(s) || /\bncat\b.*-e\s/.test(s)) return 'BLOCK';
