+    if (/:\(\)\{.*\}/.test(s)) return 'BLOCK';
+    // dd / mkfs
+    if (/\bdd\s+if=.*of=\/dev/.test(s)) return 'BLOCK';
+    if (/\bmkfs\b/.test(s)) return 'BLOCK';
