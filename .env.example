# Backend configuration
BACKEND=auto                              # auto | openclaw
PORT=3001

# OpenClaw / Clawdbot Gateway
OPENCLAW_URL=ws://127.0.0.1:18789
OPENCLAW_TOKEN=your_gateway_token_here

# Safeguard / LLM Backend
SAFEGUARD_BACKEND=lmstudio                # lmstudio | ollama | built-in | fallback
LMSTUDIO_URL=http://localhost:1234/v1     # any OpenAI-compatible endpoint works here
LMSTUDIO_MODEL=auto                       # auto | specific model name
LMSTUDIO_API_KEY=                         # optional — needed for cloud APIs (MiniMax, DeepSeek, Groq, Together, etc.)
# LLM_API_KEY=                            # alias for LMSTUDIO_API_KEY
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
ANTHROPIC_API_KEY=your_api_key_here

# Approval Handler (Intelligent Command Blocking)
GUARDCLAW_APPROVAL_MODE=auto              # auto | prompt | monitor-only
GUARDCLAW_AUTO_ALLOW_THRESHOLD=6          # Risk ≤ this: auto-allow (default: 6)
GUARDCLAW_ASK_THRESHOLD=8                 # Risk between allow and block: ask user (default: 8)
GUARDCLAW_AUTO_BLOCK_THRESHOLD=9          # Risk ≥ this: auto-block (default: 9)

# Mode descriptions:
#   auto          - Auto-allow safe commands, auto-block dangerous ones
#   prompt        - Prompt user for medium-risk commands (7-8)
#   monitor-only  - Don't intercept, just monitor and analyze

# Notification Channels (optional — approval requests pushed to your phone)
# Telegram: create a bot via @BotFather, get the chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=                          # e.g. 123456789:ABCdefGhIjKlMnOpQrStUvWxYz
TELEGRAM_CHAT_ID=                            # e.g. 123456789
# Discord: create a webhook in channel settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=                         # e.g. https://discord.com/api/webhooks/...
# WhatsApp: Meta Cloud API (developers.facebook.com → WhatsApp → API Setup)
WHATSAPP_TOKEN=                              # Permanent access token
WHATSAPP_PHONE_ID=                           # Phone number ID (not the phone number itself)
WHATSAPP_TO=                                 # Recipient phone with country code, e.g. 15126965539
WHATSAPP_VERIFY_TOKEN=guardclaw              # Webhook verification token (set same in Meta dashboard)
